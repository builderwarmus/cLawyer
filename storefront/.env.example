# ------------------------------------------------------------------
# Stripe payment keys
# ------------------------------------------------------------------
# Copy this file to ".env.local" and paste your own keys below.
# Get them free at: https://dashboard.stripe.com/apikeys
#
# Leave these blank to run the store in DEMO MODE (no real charges).
# Fill them in to accept REAL Visa / debit / credit card payments.
#
# The SECRET key stays on the server and must never be shared.
STRIPE_SECRET_KEY=

# Optional: use test keys (sk_test_...) while trying things out,
# and switch to live keys (sk_live_...) when you're ready to sell.
